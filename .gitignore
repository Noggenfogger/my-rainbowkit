# 1. 依赖管理（pnpm专属）
node_modules/
.pnpm/
.pnpm-debug.log*

# 2. Next.js 核心构建与运行时产物
.next/
out/
build/
dist/
.swc/
.serverless/
.vercel/

# 3. 环境变量（Web3项目核心安全项，严禁提交到仓库）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# 4. 通用日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 5. TypeScript 相关缓存
*.tsbuildinfo
.tsbuildinfo

# 6. 测试与覆盖率产物
coverage/
.nyc_output/
playwright-report/
test-results/

# 7. 编辑器/IDE 临时配置
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
# JetBrains 系列（WebStorm/IDEA等）
.idea/
*.iml
*.ipr
*.iws
# Sublime Text
*.sublime-project
*.sublime-workspace
# Vim/Neovim
*.swp
*.swo
*~

# 8. 系统级临时文件
# macOS
.DS_Store
# Windows
Thumbs.db
Desktop.ini

